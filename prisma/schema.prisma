// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator zod {
  provider = "zod-prisma-types"
}

model User {
  id                String              @id @default(uuid())
  authId            String              @unique
  name              String
  review            Review[]
  UsersOnReviewLike UsersOnReviewLike[]
  UsersOnReviewBad  UsersOnReviewBad[]
}

model Review {
  id                String              @id @default(uuid())
  user              User                @relation(fields: [userId], references: [id])
  userId            String
  userCode          BigInt
  message           String
  to                Character           @relation("ToCharacter", fields: [toCharacterId], references: [id])
  toCharacterId     Int
  from              Character           @relation("FromCharacter", fields: [fromCharacterId], references: [id])
  fromCharacterId   Int
  emotionFlame      Int
  createdAt         DateTime            @default(now())
  UsersOnReviewLike UsersOnReviewLike[]
  UsersOnReviewBad  UsersOnReviewBad[]
}

model UsersOnReviewLike {
  review   Review @relation(fields: [reviewId], references: [id])
  reviewId String
  user     User   @relation(fields: [userId], references: [id])
  userId   String

  @@id([reviewId, userId])
}

model UsersOnReviewBad {
  review   Review @relation(fields: [reviewId], references: [id])
  reviewId String
  user     User   @relation(fields: [userId], references: [id])
  userId   String

  @@id([reviewId, userId])
}

model Character {
  id          Int      @unique
  name        String
  toReviews   Review[] @relation("ToCharacter")
  fromReviews Review[] @relation("FromCharacter")
}
